---
config:
  theme: dark
  c4:
    fontFamily: "monospace"
---
C4Context
    title Deployment Diagram for Mem0 Infrastructure (v2)

    Person(user, "User / Developer", "Interacts with the Agent CLIs for development and research.")

    Container_Boundary(cloud, "External Cloud", "Public Internet") {
        System_Ext(ocz, "OpenCode Zen API", "Remote LLM Inference Engine (Inference Brain)")
    }

    Container_Boundary(host, "Docker Host", "Linux Environment") {
        Deployment_Node(client_net, "mem0-client network", "Docker Bridge Network") {
            Container(cli, "Agent CLI Fleet", "Python/Node.js", "mem0chat, codex, claude, gemini, etc.")
            Container(sb, "Code Sandbox", "FastAPI/Playwright", "Isolated environment for tool/code execution")
        }

        Deployment_Node(core_net, "mem0-core network", "Docker Bridge Network") {
            Container(sg, "Supergateways / mem0-mcp", "Node.js/Python", "MCP Bridge for semantic memory access")
            Container(ollama, "Ollama Service", "Ollama", "Local service for generating embeddings (mxbai-embed-large)")
        }

        Deployment_Node(storage, "Persistent Storage", "Docker Volumes / Local FS") {
            ContainerDb(db, "mem0_data volume", "SQLite", "Stores vector embeddings and long-term memories")
            ContainerDb(models, "ollama model volume", "Filesystem", "Stored weights for embedding models")
            ContainerDb(work, "Workspace Files", "Filesystem", "Shared files for code sandbox execution")
        }
    }

    %% Relationships (Tümü Standart Rel komutuna çevrildi)
    Rel(user, cli, "Uses", "Terminal/CLI")
    Rel(cli, ocz, "1. Inference", "HTTPS/REST")
    Rel(cli, sg, "2. Memory access", "HTTP/MCP")
    
    Rel(sg, ollama, "3. Embeddings", "HTTP")
    Rel(sg, db, "4. Shared CRUD", "SQLite File I/O")
    
    Rel(sb, sg, "Tools/MCP Access", "HTTP")
    Rel(sb, ollama, "Local Tests", "HTTP")
    Rel(sb, work, "File I/O", "Bind Mount")
    
    Rel(ollama, models, "Reads/Writes", "Disk")

    %% MANUEL ELEMENT STİLLERİ (Garantili Çalışanlar)
    UpdateElementStyle(user, $bgColor="#BB2528", $fontColor="#ffffff", $borderColor="#7C0000")
    UpdateElementStyle(ocz, $bgColor="#BB2528", $fontColor="#ffffff", $borderColor="#7C0000")
    UpdateElementStyle(cli, $bgColor="#006100", $fontColor="#ffffff", $borderColor="#F8B229")
    UpdateElementStyle(sb, $bgColor="#006100", $fontColor="#ffffff", $borderColor="#F8B229")
    UpdateElementStyle(sg, $bgColor="#006100", $fontColor="#ffffff", $borderColor="#F8B229")
    UpdateElementStyle(ollama, $bgColor="#006100", $fontColor="#ffffff", $borderColor="#F8B229")
    UpdateElementStyle(db, $bgColor="#a8b0a2", $fontColor="#ffffff", $borderColor="#619639")
    UpdateElementStyle(models, $bgColor="#a8b0a2", $fontColor="#ffffff", $borderColor="#619639")
    UpdateElementStyle(work, $bgColor="#a8b0a2", $fontColor="#ffffff", $borderColor="#619639")

    %% BAĞLANTI STİLLERİ (Garantili Çalışanlar)
    UpdateRelStyle(user, cli, $textColor="#F8B229", $lineColor="#F8B229")
    UpdateRelStyle(cli, ocz, $textColor="#F8B229", $lineColor="#F8B229")
    UpdateRelStyle(cli, sg, $textColor="#F8B229", $lineColor="#F8B229")
    UpdateRelStyle(sg, ollama, $textColor="#F8B229", $lineColor="#F8B229")
    UpdateRelStyle(sg, db, $textColor="#F8B229", $lineColor="#F8B229")
    UpdateRelStyle(sb, sg, $textColor="#F8B229", $lineColor="#F8B229")
    UpdateRelStyle(sb, ollama, $textColor="#F8B229", $lineColor="#F8B229")
    UpdateRelStyle(sb, work, $textColor="#F8B229", $lineColor="#F8B229")
    UpdateRelStyle(ollama, models, $textColor="#F8B229", $lineColor="#F8B229")
