---
title: "Architecture Diagram"
config:
  theme: 'dark'
  themeVariables:
    primaryColor: '#BB2528'
    primaryTextColor: '#ffffff'
    primaryBorderColor: '#7C0000'
    lineColor: '#F8B229'
    secondaryColor: '#006100'
    tertiaryColor: '#fff'
---


%% %%{init: 
%% {'flowchart': { 'defaultRenderer': 'elk' },
%% theme: 'dark',
%% securityLevel: 'loose'}}%%
graph TB
    

    User((User / Developer))

    subgraph External [External Cloud]
        OCZ[OpenCode Zen API<br/>Inference Engine]
    end

    subgraph ClientNet [Docker Containers: mem0-client network]
        CLI["Agent CLI Fleet<br/><i>(mem0chat, codex, claude, gemini,<br/>opencode, copilot, docker-ai)</i>"]
        SB[Code Sandbox<br/>Port 8080]
    end

    subgraph CoreNet [Docker: mem0-core network]
        direction TB
        SG[Supergateways / mem0-mcp<br/>Ports: 8766-8772]
        OLLAMA[[Ollama Service<br/>Port 11435]]
    end

    subgraph Storage [Persistent Storage]
        DB[(mem0_data volume<br/>memories.sqlite)]
        EMBEDDED_MODEL[(ollama backend model volume<br/>mxbai-embed-large:latest)]
        WORK[Workspace Files]
    end


    %% Flows
    User --> CLI
    CLI -- "1. Inference" --> OCZ
    CLI -- "2. Memory access (HTTP)" --> SG
    
    SG -- "3. Embeddings" --> OLLAMA
    SG -- "4. Shared CRUD" --> DB
    
    SB -- "Tools/MCP" --> SG
    SB -- "Local Tests" --> OLLAMA
    SB -- "File I/O" --> WORK
    
    OLLAMA -- "Model Storage" --> EMBEDDED_MODEL

