{
  "$schema": "https://www.getbifrost.ai/schema",
  "client": {
    "drop_excess_requests": false,
    "enforce_auth_on_inference": true,
    "enable_logging": true,
    "disable_content_logging": true,
    "log_retention_days": 90
  },
  "providers": {
    "ollama": {
      "keys": [
        {
          "name": "local-ollama",
          "value": "ollama",
          "weight": 1,
          "models": ["mxbai-embed-large", "qwen3-embedding"]
        }
      ],
      "network_config": {
        "base_url": "http://172.17.0.1:11434"
      }
    }
  },
  "mcp": {
    "client_configs": [
      {
        "name": "mem0",
        "connection_type": "http",
        "connection_string": "http://172.17.0.1:8765/mcp",
        "tools_to_execute": ["*"]
      }
    ],
    "tool_manager_config": {
      "tool_execution_timeout": 60
    }
  },
  "governance": {
    "virtual_keys": [
      {
        "id": "vk-mem0-admin",
        "name": "mem0-admin",
        "value": "sk-bf-mem0-admin",
        "is_active": true,
        "mcp_configs": [
          {
            "mcp_client_id": 1,
            "tools_to_execute": ["*"]
          }
        ]
      },
      {
        "id": "vk-mem0-readwrite",
        "name": "mem0-readwrite",
        "value": "sk-bf-mem0-rw",
        "is_active": true,
        "mcp_configs": [
          {
            "mcp_client_id": 1,
            "tools_to_execute": [
              "health",
              "memory_search",
              "memory_store",
              "memory_recall",
              "memory_update"
            ]
          }
        ]
      },
      {
        "id": "vk-mem0-readonly",
        "name": "mem0-readonly",
        "value": "sk-bf-mem0-ro",
        "is_active": true,
        "mcp_configs": [
          {
            "mcp_client_id": 1,
            "tools_to_execute": [
              "health",
              "memory_search",
              "memory_recall"
            ]
          }
        ]
      },
      {
        "id": "vk-mem0-access",
        "name": "mem0-access-legacy",
        "value": "sk-bf-mem0-local",
        "is_active": true,
        "mcp_configs": [
          {
            "mcp_client_id": 1,
            "tools_to_execute": [
              "health",
              "memory_search",
              "memory_store",
              "memory_recall",
              "memory_update"
            ]
          }
        ]
      }
    ]
  },
  "config_store": {
    "enabled": true,
    "type": "sqlite",
    "config": {
      "path": "./config.db"
    }
  },
  "logs_store": {
    "enabled": true,
    "type": "sqlite",
    "config": {
      "path": "./logs.db"
    }
  }
}
