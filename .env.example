# mem0-infrastructure environment configuration
# Copy to .env and adjust values as needed: cp .env.example .env

# === CORE (zorunlu) ===
MEM0_WORKSPACE=copernicus
MEM0_PROJECT=default

# === OLLAMA - Embedding (semantic search) ===
MEM0_EMBED_MODEL=mxbai-embed-large:latest
MEM0_OLLAMA_TIMEOUT_MS=60000

# === OLLAMA - Extraction LLM (memory fact extraction, background) ===
# This model does NOT chat with users. It extracts facts from conversations
# and manages memory lifecycle (add/update/delete).
# Upgrade to qwen3:8b or an external API if extraction quality is insufficient.
MEM0_LLM_PROVIDER=ollama
MEM0_LLM_MODEL=qwen3:1.7b

# === QDRANT (local container, no auth required) ===
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=mem0_memories
# QDRANT_API_KEY=         # only needed for remote/cloud Qdrant

# === RERANKER (disabled in foundation phase) ===
RERANK_ENABLED=false
# RERANK_PROVIDER=        # cohere | jina | local
# RERANK_MODEL=
